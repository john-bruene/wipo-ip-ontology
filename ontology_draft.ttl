@prefix : <https://w3id.org/wipo-ip#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix frbr: <http://purl.org/vocab/frbr/core#> .
@prefix lrmlmm: <http://docs.oasis-open.org/legalruleml/ns/v1.0/metamodel#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .

<https://w3id.org/wipo-ip#> a owl:Ontology ;
    dc:title "WIPO IP Ontology (draft)"@en ;
    rdfs:label "WIPO IP Ontology (draft)"@en ;
    dc:description "Draft schema (TBox only) for comparing national IP laws against WIPO treaty minimum standards. Built following Palmirani's MeLOn methodology, reusing FRBR (frbr:) for the document layer and LegalRuleML's metamodel (lrmlmm:) for the statement layer. Covers CQ1-CQ9 (national side); the treaty side (CQ10) is in the separate treaty_draft.ttl, marked as discussion material. Worked examples (Ireland, India, Kenya) that validate this schema against real statute text live in examples.ttl, kept separate on purpose: this file stays a stable, roughly constant-size schema no matter how many jurisdictions the pipeline eventually covers (up to ~200), while worked examples grow one file per batch of countries. Split 2026-07-23."@en ;
    dc:creator "John Frederic Brüne"@en ;
    owl:versionInfo "draft, 2026-07-23" .

# =============================================================================
# WIPO IP ontology, ground-up rebuild, draft (2026-07-22)
# Own terms have no prefix (plain ":"). Reused terms keep their source prefix
# (frbr:, lrmlmm:), so it is always visible what is ours and what is borrowed.
# Built step by step with John, following MeLOn; see melon_process.md and
# competency_questions.md for the reasoning behind each piece.
# This version covers CQ1-CQ9 (national side). CQ10 (compliance, needs the
# treaty side) is intentionally NOT in this file; it lives in treaty_draft.ttl,
# marked as discussion material, not a finished decision. See status.md for
# the full picture.
# IPROnto note: not actually verified in this session (the fetch returned
# unreadable binary both times tried), so rights and work types below are
# our own vocabulary, pulled from the real statute text, not from IPROnto.
#
# Schema only (TBox). Worked examples (Ireland, India, Kenya; ABox) moved out
# to examples.ttl on 2026-07-23: this file was starting to mix a ~225-line
# schema with per-country instance data growing at ~50 lines/country, which
# does not scale to the project's eventual ~200 jurisdictions. Load both
# files together (same namespace, no owl:imports needed, plain Turtle) to see
# schema + examples; point documentation/visualisation tools (Widoco, LODE,
# Graffoo, WebVOWL) at this file alone for a schema-only view.
# =============================================================================

# ===== Document layer =====
frbr:Work a owl:Class ;
    rdfs:label "Work" ;
    rdfs:comment "the law in the abstract (FRBR Work), independent of any specific dated version; see frbr:Expression for that." .
frbr:Expression a owl:Class ;
    rdfs:label "Expression" ;
    rdfs:comment "one specific dated version of a Work (FRBR Expression), e.g. the 2000 text of the Irish Copyright Act." .

frbr:realizationOf a owl:ObjectProperty ;
    rdfs:domain frbr:Expression ;
    rdfs:range frbr:Work ;
    rdfs:label "realization of" .

lrmlmm:Jurisdiction a owl:Class ;
    rdfs:label "Jurisdiction" ;
    rdfs:comment "the country or supranational body a legal Expression applies in; ISO code, or 'un' for WIPO treaties." .

:appliesInJurisdiction a owl:ObjectProperty ;
    rdfs:domain frbr:Expression ;
    rdfs:range lrmlmm:Jurisdiction ;
    rdfs:label "applies in jurisdiction" .

:inForceFrom a owl:DatatypeProperty ;
    rdfs:domain frbr:Expression ;
    rdfs:range xsd:date ;
    rdfs:label "in force from" .

:inForceTo a owl:DatatypeProperty ;
    rdfs:domain frbr:Expression ;
    rdfs:range xsd:date ;
    rdfs:label "in force to" ;
    rdfs:comment "end of the validity interval; no value means still in force. CQ5." .

# ===== Statement layer: a law contains statements =====
lrmlmm:PrescriptiveStatement a owl:Class ;
    rdfs:subClassOf lrmlmm:RuleStatement ;
    rdfs:label "Prescriptive Statement" ;
    rdfs:comment "a statement that grants, restricts, or otherwise governs conduct, e.g. a right or an exception." .
lrmlmm:ConstitutiveStatement a owl:Class ;
    rdfs:subClassOf lrmlmm:RuleStatement ;
    rdfs:label "Constitutive Statement" ;
    rdfs:comment "a statement that defines a term or establishes eligibility, without itself granting or restricting conduct." .

:contains a owl:ObjectProperty ;
    rdfs:domain frbr:Expression ;
    rdfs:range lrmlmm:RuleStatement ;
    rdfs:label "contains" ;
    rdfs:seeAlso <https://docs.oasis-open.org/legalruleml/legalruleml-core-spec/v1.0/os/rdfs/statement.rdf> ;
    rdfs:comment "range is lrmlmm:RuleStatement, LegalRuleML's own formal common superclass of ConstitutiveStatement and PrescriptiveStatement (see statement.rdf in the OASIS metamodel RDFS modules), not an ad-hoc class of ours. Used for both constitutive statements (definitions, eligibility rules) and prescriptive statements (rights, exceptions). Fixed 2026-07-22: an earlier draft wrongly restricted this to ConstitutiveStatement only; fixed 2026-07-23: gave it a real range instead of leaving it open, which had made it resolve to owl:Thing in WebVOWL." .

lrmlmm:RuleStatement a owl:Class ;
    rdfs:label "Rule Statement" ;
    rdfs:seeAlso <https://docs.oasis-open.org/legalruleml/legalruleml-core-spec/v1.0/os/rdfs/statement.rdf> ;
    rdfs:comment "a Legal Statement modelled by a Legal Rule; the formal LegalRuleML superclass of ConstitutiveStatement and PrescriptiveStatement, per the OASIS metamodel RDFS module (not part of the HTML spec's prose, only its machine-readable RDFS)." .

:amendedBy a owl:DatatypeProperty ;
    rdfs:domain lrmlmm:PrescriptiveStatement ;
    rdfs:range xsd:string ;
    rdfs:label "amended by" ;
    rdfs:comment "which later Act changed this statement's wording, when the text itself says so (here, a footnote). CQ11, kept modest: this is not a full historical Expression, that would need the pre-amendment text itself, which we do not have cached yet." .

# ===== Content layer: rights =====
:Copyright a owl:Class ;
    rdfs:label "Copyright" ;
    rdfs:comment "the bundle of rights a Work carries; which specific acts it covers is given via :includesAct." .

:hasRight a owl:ObjectProperty ;
    rdfs:domain frbr:Work ;
    rdfs:range :Copyright ;
    rdfs:label "has right" .

:expresses a owl:ObjectProperty ;
    rdfs:domain lrmlmm:PrescriptiveStatement ;
    rdfs:range :Copyright ;
    rdfs:label "expresses" .

:RightKind a owl:Class ;
    rdfs:label "Right Kind" ;
    rdfs:seeAlso <https://rhizomik.net/html/~roberto/papers/rg-losw08.pdf> , <https://jurix.nl/pdf/j03-12.pdf> ;
    rdfs:comment "matches the Economic Rights hierarchy in Garcia & Gil's Copyright Ontology (JURIX 2008): Reproduction, Distribution, Communication (with Broadcasting and Making Available as subtypes), Transformation (with Adaptation and Translation as subtypes), Fixation. That hierarchy refines the four top-level ExploitationRight classes (Reproduction, Communication, Distribution, Transformation) in Delgado et al.'s earlier IPROnto (JURIX 2003). All eight individuals below have a direct counterpart in the 2008 version." .
:ReproductionAct a :RightKind .
:DistributionAct a :RightKind .
:CommunicationToPublicAct a :RightKind .
:MakingAvailableAct a :RightKind .
:TranslationAct a :RightKind .
:AdaptationAct a :RightKind .
:BroadcastingAct a :RightKind .
:RecordingAct a :RightKind ;
    rdfs:comment "making a film or sound recording of the work; found in India's list, not (yet) in Ireland's or Kenya's." .

:includesAct a owl:ObjectProperty ;
    rdfs:domain :Copyright ;
    rdfs:range :RightKind ;
    rdfs:label "includes act" ;
    rdfs:comment "CQ2. Which acts a copyright covers; a country can list several. Mapping these across countries is an approximation, not a formal equivalence: Ireland's single 'make available to the public' is treated here as the closest match to what India and Kenya sometimes split into distribution, communication to the public, and making available as separate items. Flagged here, not silently assumed as equal." .

# ===== Content layer: subject matter (work types) =====
:WorkType a owl:Class ;
    rdfs:label "Work Type" ;
    rdfs:comment "the kind of subject matter a Copyright or ExceptionOrLimitation applies to, e.g. literary work or sound recording." .
:LiteraryWork a :WorkType .
:SoundRecording a :WorkType .

:appliesTo a owl:ObjectProperty ;
    rdfs:range :WorkType ;
    rdfs:label "applies to" ;
    rdfs:comment "domain intentionally left open: used for Copyright and for ExceptionOrLimitation alike, same fix as :contains above." .

# ===== Content layer: duration =====
:ProtectionTerm a owl:Class ;
    rdfs:label "Protection Term" ;
    rdfs:comment "how long a Copyright lasts: a value, a unit, and the event it is counted from." .

:hasTerm a owl:ObjectProperty ;
    rdfs:domain :Copyright ;
    rdfs:range :ProtectionTerm ;
    rdfs:label "has term" .

:termValue a owl:DatatypeProperty ;
    rdfs:domain :ProtectionTerm ;
    rdfs:range xsd:integer ;
    rdfs:label "term value" .

:TimeUnit a owl:Class ;
    rdfs:label "Time Unit" ;
    rdfs:comment "the unit a ProtectionTerm's value is counted in, e.g. year or month." .
:Year a :TimeUnit .
:Month a :TimeUnit .

:termUnit a owl:ObjectProperty ;
    rdfs:domain :ProtectionTerm ;
    rdfs:range :TimeUnit ;
    rdfs:label "term unit" .

:ReferenceEvent a owl:Class ;
    rdfs:label "Reference Event" ;
    rdfs:comment "the event a ProtectionTerm is counted from, e.g. the author's death or the work's creation." .
:AuthorDeath a :ReferenceEvent .
:Creation a :ReferenceEvent .

:countedFrom a owl:ObjectProperty ;
    rdfs:domain :ProtectionTerm ;
    rdfs:range :ReferenceEvent ;
    rdfs:label "counted from" .

# ===== Content layer: exceptions =====
:ExceptionOrLimitation a owl:Class ;
    rdfs:label "Exception or Limitation" ;
    rdfs:comment "a country-specific carve-out from Copyright, e.g. Ireland's fair dealing for research; classified by one or more ExceptionKind." .

:ExceptionKind a owl:Class ;
    rdfs:label "Exception Kind" ;
    rdfs:seeAlso <https://rhizomik.net/html/~roberto/papers/rg-losw08.pdf> ;
    rdfs:comment "the same Copyright Ontology (Garcia & Gil, JURIX 2008) lists seven exceptions: Quotation, Education, Information, Official Act, Private Copy, Parody, Temporary Reproduction. PrivateUseException and ParodyException match exactly (Private Copy, Parody); ResearchException, CriticismReviewException and NewsReportingException are only approximate matches to Education, Quotation and Information respectively, not identical in scope, flagged here rather than assumed equivalent." .
:PrivateUseException a :ExceptionKind .
:ResearchException a :ExceptionKind .
:CriticismReviewException a :ExceptionKind .
:NewsReportingException a :ExceptionKind .
:ParodyException a :ExceptionKind ;
    rdfs:comment "found in Kenya's exceptions list, not (yet) confirmed in Ireland's or India's." .

:ofExceptionKind a owl:ObjectProperty ;
    rdfs:domain :ExceptionOrLimitation ;
    rdfs:range :ExceptionKind ;
    rdfs:label "of exception kind" .

:subjectToException a owl:ObjectProperty ;
    rdfs:domain :Copyright ;
    rdfs:range :ExceptionOrLimitation ;
    rdfs:label "subject to exception" .

# CQ6 (eligibility / point of attachment): removed 2026-07-23, not deferred,
# a deliberate decision. Was one flat class, revised same day into a
# Berne-vs-Rome split (:AuthorsRightsAttachment / :RelatedRightsAttachment),
# then pulled entirely: the split was correct but two thirds unused (three
# Rome individuals with no worked example, only Ireland asserting the Berne
# side), and John judged that not solid enough to stand behind in tomorrow's
# meeting. Better absent than half-built. See status.md.

# ===== Treaty membership (CQ9) =====
:TreatyMembership a owl:Class ;
    rdfs:label "Treaty Membership" ;
    rdfs:comment "records that a Jurisdiction is a member of a treaty (frbr:Work) since a given date. CQ9." .

:memberJurisdiction a owl:ObjectProperty ;
    rdfs:domain :TreatyMembership ;
    rdfs:range lrmlmm:Jurisdiction ;
    rdfs:label "member jurisdiction" .

:memberOfTreaty a owl:ObjectProperty ;
    rdfs:domain :TreatyMembership ;
    rdfs:range frbr:Work ;
    rdfs:label "member of treaty" .

:sinceDate a owl:DatatypeProperty ;
    rdfs:domain :TreatyMembership ;
    rdfs:range xsd:date ;
    rdfs:label "since date" .

:BerneConvention a frbr:Work ;
    rdfs:label "Berne Convention for the Protection of Literary and Artistic Works" .
