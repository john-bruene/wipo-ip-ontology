<?xml version="1.0"?>
<rdf:RDF xmlns="https://w3id.org/wipo-ip#"
     xml:base="https://w3id.org/wipo-ip"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="https://w3id.org/wipo-ip#">
        <dc:creator xml:lang="en">John Frederic Brüne</dc:creator>
        <dc:description xml:lang="en">Draft schema (TBox only) for comparing national IP laws against WIPO treaty minimum standards. Built following Palmirani&apos;s MeLOn methodology, reusing FRBR (frbr:) for the document layer and LegalRuleML&apos;s metamodel (lrmlmm:) for the statement layer. Covers CQ1-CQ9 (national side); the treaty side (CQ10) is in the separate treaty_draft.ttl, marked as discussion material. Worked examples (Ireland, India, Kenya) that validate this schema against real statute text live in examples.ttl, kept separate on purpose: this file stays a stable, roughly constant-size schema no matter how many jurisdictions the pipeline eventually covers (up to ~200), while worked examples grow one file per batch of countries. Split 2026-07-23.</dc:description>
        <dc:title xml:lang="en">WIPO IP Ontology (draft)</dc:title>
        <rdfs:label xml:lang="en">WIPO IP Ontology (draft)</rdfs:label>
        <owl:versionInfo>draft, 2026-07-23</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/elements/1.1/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/creator"/>
    


    <!-- http://purl.org/dc/elements/1.1/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/description"/>
    


    <!-- http://purl.org/dc/elements/1.1/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/title"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/vocab/frbr/core#realizationOf -->


    <owl:ObjectProperty rdf:about="http://purl.org/vocab/frbr/core#realizationOf">
        <rdfs:domain rdf:resource="http://purl.org/vocab/frbr/core#Expression"/>
        <rdfs:range rdf:resource="http://purl.org/vocab/frbr/core#Work"/>
        <rdfs:label>realization of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wipo-ip#appliesInJurisdiction -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wipo-ip#appliesInJurisdiction">
        <rdfs:domain rdf:resource="http://purl.org/vocab/frbr/core#Expression"/>
        <rdfs:range rdf:resource="http://docs.oasis-open.org/legalruleml/ns/v1.0/metamodel#Jurisdiction"/>
        <rdfs:label>applies in jurisdiction</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wipo-ip#appliesTo -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wipo-ip#appliesTo">
        <rdfs:range rdf:resource="https://w3id.org/wipo-ip#WorkType"/>
        <rdfs:comment>domain intentionally left open: used for Copyright and for ExceptionOrLimitation alike, same fix as :contains above.</rdfs:comment>
        <rdfs:label>applies to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wipo-ip#contains -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wipo-ip#contains">
        <rdfs:domain rdf:resource="http://purl.org/vocab/frbr/core#Expression"/>
        <rdfs:range rdf:resource="http://docs.oasis-open.org/legalruleml/ns/v1.0/metamodel#RuleStatement"/>
        <rdfs:comment>range is lrmlmm:RuleStatement, LegalRuleML&apos;s own formal common superclass of ConstitutiveStatement and PrescriptiveStatement (see statement.rdf in the OASIS metamodel RDFS modules), not an ad-hoc class of ours. Used for both constitutive statements (definitions, eligibility rules) and prescriptive statements (rights, exceptions). Fixed 2026-07-22: an earlier draft wrongly restricted this to ConstitutiveStatement only; fixed 2026-07-23: gave it a real range instead of leaving it open, which had made it resolve to owl:Thing in WebVOWL.</rdfs:comment>
        <rdfs:label>contains</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://docs.oasis-open.org/legalruleml/legalruleml-core-spec/v1.0/os/rdfs/statement.rdf"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wipo-ip#countedFrom -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wipo-ip#countedFrom">
        <rdfs:domain rdf:resource="https://w3id.org/wipo-ip#ProtectionTerm"/>
        <rdfs:range rdf:resource="https://w3id.org/wipo-ip#ReferenceEvent"/>
        <rdfs:label>counted from</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wipo-ip#expresses -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wipo-ip#expresses">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/legalruleml/ns/v1.0/metamodel#PrescriptiveStatement"/>
        <rdfs:range rdf:resource="https://w3id.org/wipo-ip#Copyright"/>
        <rdfs:label>expresses</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wipo-ip#hasRight -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wipo-ip#hasRight">
        <rdfs:domain rdf:resource="http://purl.org/vocab/frbr/core#Work"/>
        <rdfs:range rdf:resource="https://w3id.org/wipo-ip#Copyright"/>
        <rdfs:label>has right</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wipo-ip#hasTerm -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wipo-ip#hasTerm">
        <rdfs:domain rdf:resource="https://w3id.org/wipo-ip#Copyright"/>
        <rdfs:range rdf:resource="https://w3id.org/wipo-ip#ProtectionTerm"/>
        <rdfs:label>has term</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wipo-ip#includesAct -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wipo-ip#includesAct">
        <rdfs:domain rdf:resource="https://w3id.org/wipo-ip#Copyright"/>
        <rdfs:range rdf:resource="https://w3id.org/wipo-ip#RightKind"/>
        <rdfs:comment>CQ2. Which acts a copyright covers; a country can list several. Mapping these across countries is an approximation, not a formal equivalence: Ireland&apos;s single &apos;make available to the public&apos; is treated here as the closest match to what India and Kenya sometimes split into distribution, communication to the public, and making available as separate items. Flagged here, not silently assumed as equal.</rdfs:comment>
        <rdfs:label>includes act</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wipo-ip#memberJurisdiction -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wipo-ip#memberJurisdiction">
        <rdfs:domain rdf:resource="https://w3id.org/wipo-ip#TreatyMembership"/>
        <rdfs:range rdf:resource="http://docs.oasis-open.org/legalruleml/ns/v1.0/metamodel#Jurisdiction"/>
        <rdfs:label>member jurisdiction</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wipo-ip#memberOfTreaty -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wipo-ip#memberOfTreaty">
        <rdfs:domain rdf:resource="https://w3id.org/wipo-ip#TreatyMembership"/>
        <rdfs:range rdf:resource="http://purl.org/vocab/frbr/core#Work"/>
        <rdfs:label>member of treaty</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wipo-ip#ofExceptionKind -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wipo-ip#ofExceptionKind">
        <rdfs:domain rdf:resource="https://w3id.org/wipo-ip#ExceptionOrLimitation"/>
        <rdfs:range rdf:resource="https://w3id.org/wipo-ip#ExceptionKind"/>
        <rdfs:label>of exception kind</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wipo-ip#subjectToException -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wipo-ip#subjectToException">
        <rdfs:domain rdf:resource="https://w3id.org/wipo-ip#Copyright"/>
        <rdfs:range rdf:resource="https://w3id.org/wipo-ip#ExceptionOrLimitation"/>
        <rdfs:label>subject to exception</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/wipo-ip#termUnit -->


    <owl:ObjectProperty rdf:about="https://w3id.org/wipo-ip#termUnit">
        <rdfs:domain rdf:resource="https://w3id.org/wipo-ip#ProtectionTerm"/>
        <rdfs:range rdf:resource="https://w3id.org/wipo-ip#TimeUnit"/>
        <rdfs:label>term unit</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://w3id.org/wipo-ip#amendedBy -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/wipo-ip#amendedBy">
        <rdfs:domain rdf:resource="http://docs.oasis-open.org/legalruleml/ns/v1.0/metamodel#PrescriptiveStatement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>which later Act changed this statement&apos;s wording, when the text itself says so (here, a footnote). CQ11, kept modest: this is not a full historical Expression, that would need the pre-amendment text itself, which we do not have cached yet.</rdfs:comment>
        <rdfs:label>amended by</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/wipo-ip#inForceFrom -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/wipo-ip#inForceFrom">
        <rdfs:domain rdf:resource="http://purl.org/vocab/frbr/core#Expression"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:label>in force from</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/wipo-ip#inForceTo -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/wipo-ip#inForceTo">
        <rdfs:domain rdf:resource="http://purl.org/vocab/frbr/core#Expression"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>end of the validity interval; no value means still in force. CQ5.</rdfs:comment>
        <rdfs:label>in force to</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/wipo-ip#sinceDate -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/wipo-ip#sinceDate">
        <rdfs:domain rdf:resource="https://w3id.org/wipo-ip#TreatyMembership"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:label>since date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/wipo-ip#termValue -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/wipo-ip#termValue">
        <rdfs:domain rdf:resource="https://w3id.org/wipo-ip#ProtectionTerm"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label>term value</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://docs.oasis-open.org/legalruleml/ns/v1.0/metamodel#ConstitutiveStatement -->


    <owl:Class rdf:about="http://docs.oasis-open.org/legalruleml/ns/v1.0/metamodel#ConstitutiveStatement">
        <rdfs:subClassOf rdf:resource="http://docs.oasis-open.org/legalruleml/ns/v1.0/metamodel#RuleStatement"/>
        <rdfs:comment>a statement that defines a term or establishes eligibility, without itself granting or restricting conduct.</rdfs:comment>
        <rdfs:label>Constitutive Statement</rdfs:label>
    </owl:Class>
    


    <!-- http://docs.oasis-open.org/legalruleml/ns/v1.0/metamodel#Jurisdiction -->


    <owl:Class rdf:about="http://docs.oasis-open.org/legalruleml/ns/v1.0/metamodel#Jurisdiction">
        <rdfs:comment>the country or supranational body a legal Expression applies in; ISO code, or &apos;un&apos; for WIPO treaties.</rdfs:comment>
        <rdfs:label>Jurisdiction</rdfs:label>
    </owl:Class>
    


    <!-- http://docs.oasis-open.org/legalruleml/ns/v1.0/metamodel#PrescriptiveStatement -->


    <owl:Class rdf:about="http://docs.oasis-open.org/legalruleml/ns/v1.0/metamodel#PrescriptiveStatement">
        <rdfs:subClassOf rdf:resource="http://docs.oasis-open.org/legalruleml/ns/v1.0/metamodel#RuleStatement"/>
        <rdfs:comment>a statement that grants, restricts, or otherwise governs conduct, e.g. a right or an exception.</rdfs:comment>
        <rdfs:label>Prescriptive Statement</rdfs:label>
    </owl:Class>
    


    <!-- http://docs.oasis-open.org/legalruleml/ns/v1.0/metamodel#RuleStatement -->


    <owl:Class rdf:about="http://docs.oasis-open.org/legalruleml/ns/v1.0/metamodel#RuleStatement">
        <rdfs:comment>a Legal Statement modelled by a Legal Rule; the formal LegalRuleML superclass of ConstitutiveStatement and PrescriptiveStatement, per the OASIS metamodel RDFS module (not part of the HTML spec&apos;s prose, only its machine-readable RDFS).</rdfs:comment>
        <rdfs:label>Rule Statement</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://docs.oasis-open.org/legalruleml/legalruleml-core-spec/v1.0/os/rdfs/statement.rdf"/>
    </owl:Class>
    


    <!-- http://purl.org/vocab/frbr/core#Expression -->


    <owl:Class rdf:about="http://purl.org/vocab/frbr/core#Expression">
        <rdfs:comment>one specific dated version of a Work (FRBR Expression), e.g. the 2000 text of the Irish Copyright Act.</rdfs:comment>
        <rdfs:label>Expression</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.org/vocab/frbr/core#Work -->


    <owl:Class rdf:about="http://purl.org/vocab/frbr/core#Work">
        <rdfs:comment>the law in the abstract (FRBR Work), independent of any specific dated version; see frbr:Expression for that.</rdfs:comment>
        <rdfs:label>Work</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/wipo-ip#Copyright -->


    <owl:Class rdf:about="https://w3id.org/wipo-ip#Copyright">
        <rdfs:comment>the bundle of rights a Work carries; which specific acts it covers is given via :includesAct.</rdfs:comment>
        <rdfs:label>Copyright</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/wipo-ip#ExceptionKind -->


    <owl:Class rdf:about="https://w3id.org/wipo-ip#ExceptionKind">
        <rdfs:comment>the same Copyright Ontology (Garcia &amp; Gil, JURIX 2008) lists seven exceptions: Quotation, Education, Information, Official Act, Private Copy, Parody, Temporary Reproduction. PrivateUseException and ParodyException match exactly (Private Copy, Parody); ResearchException, CriticismReviewException and NewsReportingException are only approximate matches to Education, Quotation and Information respectively, not identical in scope, flagged here rather than assumed equivalent.</rdfs:comment>
        <rdfs:label>Exception Kind</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://rhizomik.net/html/~roberto/papers/rg-losw08.pdf"/>
    </owl:Class>
    


    <!-- https://w3id.org/wipo-ip#ExceptionOrLimitation -->


    <owl:Class rdf:about="https://w3id.org/wipo-ip#ExceptionOrLimitation">
        <rdfs:comment>a country-specific carve-out from Copyright, e.g. Ireland&apos;s fair dealing for research; classified by one or more ExceptionKind.</rdfs:comment>
        <rdfs:label>Exception or Limitation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/wipo-ip#ProtectionTerm -->


    <owl:Class rdf:about="https://w3id.org/wipo-ip#ProtectionTerm">
        <rdfs:comment>how long a Copyright lasts: a value, a unit, and the event it is counted from.</rdfs:comment>
        <rdfs:label>Protection Term</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/wipo-ip#ReferenceEvent -->


    <owl:Class rdf:about="https://w3id.org/wipo-ip#ReferenceEvent">
        <rdfs:comment>the event a ProtectionTerm is counted from, e.g. the author&apos;s death or the work&apos;s creation.</rdfs:comment>
        <rdfs:label>Reference Event</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/wipo-ip#RightKind -->


    <owl:Class rdf:about="https://w3id.org/wipo-ip#RightKind">
        <rdfs:comment>matches the Economic Rights hierarchy in Garcia &amp; Gil&apos;s Copyright Ontology (JURIX 2008), checked directly against that paper: Reproduction, Distribution, Communication (with Broadcasting and Making Available as subtypes), Transformation (with Adaptation and Translation as subtypes), Fixation. All eight individuals below have a direct counterpart in that 2008 hierarchy. Garcia &amp; Gil describe this hierarchy as refining the four top-level ExploitationRight classes (Reproduction, Communication, Distribution, Transformation) in Delgado et al.&apos;s earlier IPROnto (JURIX 2003); that IPROnto characterization is taken from Garcia &amp; Gil&apos;s own literature review, not independently checked against the IPROnto source itself in this session (an earlier fetch attempt failed).</rdfs:comment>
        <rdfs:label>Right Kind</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://jurix.nl/pdf/j03-12.pdf"/>
        <rdfs:seeAlso rdf:resource="https://rhizomik.net/html/~roberto/papers/rg-losw08.pdf"/>
    </owl:Class>
    


    <!-- https://w3id.org/wipo-ip#TimeUnit -->


    <owl:Class rdf:about="https://w3id.org/wipo-ip#TimeUnit">
        <rdfs:comment>the unit a ProtectionTerm&apos;s value is counted in, e.g. year or month.</rdfs:comment>
        <rdfs:label>Time Unit</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/wipo-ip#TreatyMembership -->


    <owl:Class rdf:about="https://w3id.org/wipo-ip#TreatyMembership">
        <rdfs:comment>records that a Jurisdiction is a member of a treaty (frbr:Work) since a given date. CQ9.</rdfs:comment>
        <rdfs:label>Treaty Membership</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/wipo-ip#WorkType -->


    <owl:Class rdf:about="https://w3id.org/wipo-ip#WorkType">
        <rdfs:comment>the kind of subject matter a Copyright or ExceptionOrLimitation applies to, e.g. literary work or sound recording.</rdfs:comment>
        <rdfs:label>Work Type</rdfs:label>
    </owl:Class>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://w3id.org/wipo-ip#AdaptationAct -->


    <owl:NamedIndividual rdf:about="https://w3id.org/wipo-ip#AdaptationAct">
        <rdf:type rdf:resource="https://w3id.org/wipo-ip#RightKind"/>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/wipo-ip#AuthorDeath -->


    <owl:NamedIndividual rdf:about="https://w3id.org/wipo-ip#AuthorDeath">
        <rdf:type rdf:resource="https://w3id.org/wipo-ip#ReferenceEvent"/>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/wipo-ip#BerneConvention -->


    <owl:NamedIndividual rdf:about="https://w3id.org/wipo-ip#BerneConvention">
        <rdf:type rdf:resource="http://purl.org/vocab/frbr/core#Work"/>
        <rdfs:label>Berne Convention for the Protection of Literary and Artistic Works</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/wipo-ip#BroadcastingAct -->


    <owl:NamedIndividual rdf:about="https://w3id.org/wipo-ip#BroadcastingAct">
        <rdf:type rdf:resource="https://w3id.org/wipo-ip#RightKind"/>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/wipo-ip#CommunicationToPublicAct -->


    <owl:NamedIndividual rdf:about="https://w3id.org/wipo-ip#CommunicationToPublicAct">
        <rdf:type rdf:resource="https://w3id.org/wipo-ip#RightKind"/>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/wipo-ip#Creation -->


    <owl:NamedIndividual rdf:about="https://w3id.org/wipo-ip#Creation">
        <rdf:type rdf:resource="https://w3id.org/wipo-ip#ReferenceEvent"/>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/wipo-ip#CriticismReviewException -->


    <owl:NamedIndividual rdf:about="https://w3id.org/wipo-ip#CriticismReviewException">
        <rdf:type rdf:resource="https://w3id.org/wipo-ip#ExceptionKind"/>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/wipo-ip#DistributionAct -->


    <owl:NamedIndividual rdf:about="https://w3id.org/wipo-ip#DistributionAct">
        <rdf:type rdf:resource="https://w3id.org/wipo-ip#RightKind"/>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/wipo-ip#LiteraryWork -->


    <owl:NamedIndividual rdf:about="https://w3id.org/wipo-ip#LiteraryWork">
        <rdf:type rdf:resource="https://w3id.org/wipo-ip#WorkType"/>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/wipo-ip#MakingAvailableAct -->


    <owl:NamedIndividual rdf:about="https://w3id.org/wipo-ip#MakingAvailableAct">
        <rdf:type rdf:resource="https://w3id.org/wipo-ip#RightKind"/>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/wipo-ip#Month -->


    <owl:NamedIndividual rdf:about="https://w3id.org/wipo-ip#Month">
        <rdf:type rdf:resource="https://w3id.org/wipo-ip#TimeUnit"/>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/wipo-ip#NewsReportingException -->


    <owl:NamedIndividual rdf:about="https://w3id.org/wipo-ip#NewsReportingException">
        <rdf:type rdf:resource="https://w3id.org/wipo-ip#ExceptionKind"/>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/wipo-ip#ParodyException -->


    <owl:NamedIndividual rdf:about="https://w3id.org/wipo-ip#ParodyException">
        <rdf:type rdf:resource="https://w3id.org/wipo-ip#ExceptionKind"/>
        <rdfs:comment>found in Kenya&apos;s exceptions list, not (yet) confirmed in Ireland&apos;s or India&apos;s.</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/wipo-ip#PrivateUseException -->


    <owl:NamedIndividual rdf:about="https://w3id.org/wipo-ip#PrivateUseException">
        <rdf:type rdf:resource="https://w3id.org/wipo-ip#ExceptionKind"/>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/wipo-ip#RecordingAct -->


    <owl:NamedIndividual rdf:about="https://w3id.org/wipo-ip#RecordingAct">
        <rdf:type rdf:resource="https://w3id.org/wipo-ip#RightKind"/>
        <rdfs:comment>making a film or sound recording of the work; found in India&apos;s list, not (yet) in Ireland&apos;s or Kenya&apos;s.</rdfs:comment>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/wipo-ip#ReproductionAct -->


    <owl:NamedIndividual rdf:about="https://w3id.org/wipo-ip#ReproductionAct">
        <rdf:type rdf:resource="https://w3id.org/wipo-ip#RightKind"/>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/wipo-ip#ResearchException -->


